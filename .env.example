# ===== FRONTEND ENVIRONMENT VARIABLES (VITE_) =====
# These variables are exposed to the frontend via Vite during build time.
# All frontend-facing variables must be prefixed with VITE_

# VITE_APP_URL: The URL where this application is hosted.
# Used for self-referential links, OAuth callbacks, and production verification.
# Local: http://localhost:3000
# Production (Vercel): https://your-production-domain.com
# Production (Cloud Run): https://your-cloud-run-service.run.app
VITE_APP_URL="http://localhost:3000"

# ===== BACKEND ENVIRONMENT VARIABLES (Non-VITE) =====
# These variables are NOT exposed to the frontend and are backend-only.

# PORT: Server port (default: 3000)
PORT=3000

# NODE_ENV: Environment (development, production)
NODE_ENV="development"

# JWT_SECRET: Secret for signing JWT tokens.
# CRITICAL: Use a strong, unique secret in production!
JWT_SECRET="Put_Your_Secert_Password"

# APP_URL: (Optional) Backend-side self-referential URL for generating links.
# If not set, defaults to VITE_APP_URL or localhost:3000
# APP_URL="http://localhost:3000"

# ===== FIREBASE CONFIGURATION (VITE_ for Frontend) =====
# These are the public Firebase configuration values from your Firebase project.
# Safe to be exposed to the frontend via Vite.

VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""
# Optional: For multi-database projects
# VITE_FIREBASE_DATABASE_ID=""