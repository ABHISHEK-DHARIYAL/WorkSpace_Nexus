{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "tsx backend/server.ts",
    "build": "vite build && esbuild backend/app.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=backend/app.js && esbuild backend/server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs",
    "start": "node dist/server.cjs",
    "clean": "rm -rf dist backend/app.js backend/app.js.map dist/server.cjs dist/server.cjs.map",
    "lint": "tsc --noEmit"
  },
